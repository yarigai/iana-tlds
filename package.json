{
  "name": "@yarigai/iana-tlds",
  "version": "1.0.27",
  "description": "Always up-to-date list of valid Top-Level Domains (TLDs) sourced directly from IANA",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "update-tlds": "node scripts/update-tlds.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepack": "pnpm run build",
    "release": "f() { pnpm version ${1:-patch} && git push && git push --tags; }; f"
  },
  "keywords": [
    "iana",
    "tld",
    "tlds",
    "domains",
    "validation",
    "email"
  ],
  "author": {
    "name": "Yarigai",
    "email": "hola@yarigai.mx",
    "url": "https://yarigai.mx"
  },
  "funding": {
    "type": "individual",
    "url": "https://yarigai.mx"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yarigai/iana-tlds.git"
  },
  "bugs": {
    "url": "https://github.com/yarigai/iana-tlds/issues"
  },
  "homepage": "https://github.com/yarigai/iana-tlds#readme",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.8.3",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.4",
    "vitest": "3.2.4"
  }
}
